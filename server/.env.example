# ============================================
# ClearCorex backend — environment template
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git.
# ============================================

# --- Server ---
PORT=3000

# Public URL where the site is reachable (used in email links)
PUBLIC_URL=http://localhost:3000

# --- Amazon SES SMTP ---
# Get these from AWS Console → SES → SMTP settings → Create SMTP credentials.
# Pick the SMTP endpoint matching the AWS region your SES is verified in.
# us-east-1   → email-smtp.us-east-1.amazonaws.com
# us-west-2   → email-smtp.us-west-2.amazonaws.com
# eu-west-1   → email-smtp.eu-west-1.amazonaws.com
# ap-southeast-1 → email-smtp.ap-southeast-1.amazonaws.com
SES_HOST=email-smtp.us-east-1.amazonaws.com
SES_PORT=587
SES_USER=YOUR_SMTP_USER_HERE
SES_PASS=YOUR_SMTP_PASSWORD_HERE

# Address that emails appear to come from.
# MUST be a verified identity in your SES account (verified email or verified domain).
MAIL_FROM_NAME=ClearCorex
MAIL_FROM_ADDRESS=updates@yourdomain.com

# --- Download ---
# Filename of the installer placed in /server/downloads/
DOWNLOAD_FILENAME=ClearCorex-Setup-4.0.2.exe

# Optional: comma-separated allowed CORS origins.
# Leave empty if frontend is served by this same backend.
CORS_ORIGINS=
